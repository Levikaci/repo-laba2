<Window x:Class="ChemistryApp2.PeriodicTableView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Таблица Менделеева" Height="780" Width="1320"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Периодическая система химических элементов Д.И. Менделеева" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,12" 
                   Foreground="#2C3E50" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Grid x:Name="PeriodicGrid" Margin="5" Background="Transparent"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,5,0,10" 
                BorderThickness="1" BorderBrush="#E0E0E0">
            <StackPanel>
                <TextBlock x:Name="InfoTitle" FontSize="17" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock x:Name="InfoDetails" TextWrapping="Wrap" Margin="0,8,0,0" 
                           FontSize="13" Foreground="#555" LineHeight="18"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="12" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Категории: " FontWeight="Bold" VerticalAlignment="Center" 
                           Margin="0,0,8,0" Foreground="#2C3E50"/>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#E91E63" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Неметаллы" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#2196F3" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Металлы" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#FFC107" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Металлоиды" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#9C27B0" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Инертные газы" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#00BCD4" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Галогены" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#FF5722" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Лантаноиды" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2,0">
                    <Rectangle Width="20" Height="16" Fill="#795548" RadiusX="3" RadiusY="3" Stroke="#333" StrokeThickness="0.5"/>
                    <TextBlock Text=" Актиноиды" FontSize="10" VerticalAlignment="Center" Foreground="#555"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>