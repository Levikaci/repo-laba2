<Window x:Class="ChemistryApp2.TopicsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChemistryApp2"
        Title="Управление темами" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F9FA">

    <!-- 🔥 Ресурсы окна - здесь определяем шаблон -->
    <Window.Resources>
        <DataTemplate x:Key="TopicItemTemplate" DataType="{x:Type local:Topic}">
            <StackPanel Margin="5">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="{Binding Content}" FontSize="11" 
                           Foreground="#666" TextWrapping="Wrap" MaxHeight="40"/>
                <TextBlock Text="{Binding SortOrder, StringFormat='Порядок: {0}'}" 
                           FontSize="10" Foreground="#999" Margin="0,3,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Темы курса" FontSize="20" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- 🔥 Теперь ресурс доступен -->
        <ListBox x:Name="TopicsList" Grid.Row="1" 
                 Background="White" BorderBrush="#DDD" BorderThickness="1"
                 SelectionChanged="TopicsList_SelectionChanged"
                 ItemTemplate="{StaticResource TopicItemTemplate}"
                 Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Обновить" Click="Refresh_Click" Width="90" Margin="0,0,10,0" 
                    Background="#6C757D" Foreground="White"/>
            <Button Content="Закрыть" Click="Close_Click" Width="90" 
                    Background="#007BFF" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>